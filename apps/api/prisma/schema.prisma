generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model WorkBlock {
  id        String   @id @default(uuid())
  title     String
  notes     String?
  startedAt DateTime
  endedAt   DateTime
  tags      Tag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([startedAt])
  @@index([endedAt])
}

model Tag {
  id         String      @id @default(uuid())
  name       String      @unique
  color      String
  workBlocks WorkBlock[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}
