{
  "name": "time-tracker",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api start:dev",
    "dev:desktop": "pnpm --filter web tauri:dev",
    "build:web": "pnpm --filter web build",
    "build:api": "pnpm --filter api build",
    "build:desktop": "pnpm --filter web tauri:build",
    "build:desktop:linux": "pnpm --filter web tauri:build:linux",
    "build:desktop:windows": "pnpm --filter web tauri:build:windows",
    "db:migrate": "pnpm --filter api exec prisma migrate dev",
    "db:generate": "pnpm --filter api exec prisma generate",
    "db:studio": "pnpm --filter api exec prisma studio",
    "db:seed": "pnpm --filter api run db:seed",
    "db:seed:one": "pnpm --filter api run db:seed:one",
    "db:reset": "pnpm --filter api run db:reset",
    "dev": "concurrently \"pnpm dev:api\" \"pnpm dev:desktop\""
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}
